#!/bin/sh

WGET="/bin/busybox wget --no-check-certificate"
BBOX="/bin/busybox"
DPKG="/usr/bin/dpkg"
STATUS_DB="/var/lib/dpkg/status"
APT_LISTS_DIR="/var/lib/apt/lists"
APT_ARCHIVE_DIR="/var/cache/apt/archives"
SOURCES_LIST="/etc/apt/sources.list"

error() { echo "E: $*" >&2; }
warn()  { echo "W: $*" >&2; }
info()  { echo "I: $*"; }

ensure_dirs() {
    for d in "$APT_LISTS_DIR/partial" "$APT_ARCHIVE_DIR/partial"; do
        [ -d "$d" ] || mkdir -p "$d" 2>/dev/null || { error "Could not create $d"; exit 1; }
    done
}

wget_download() {
    local_url="$1"
    out="$2"
    $WGET -q -O "$out" "$local_url" && [ -s "$out" ]
}

trim_squeeze() {
    printf '%s' "$1" | $BBOX tr -s ' \t' ' ' | $BBOX sed 's/^[[:space:]]*//;s/[[:space:]]*$//'
}

parse_sources() {
    while IFS= read -r line; do
        line="${line%%#*}"
        line="$(trim_squeeze "$line")"
        [ -z "$line" ] && continue
        set -- $line
        [ "$1" = "deb" ] || continue
        url="$2"
        case "$url" in
            \[*) url="$3"; dist="$4"; shift 4 ;;
            *)   dist="$3"; shift 3 ;;
        esac
        echo "deb|$url|$dist|$*"
    done
}

pkg_list_files() {
    ls "$APT_LISTS_DIR"/*_Packages 2>/dev/null
}

get_repo_url() {
    parse_sources < "$SOURCES_LIST" | {
        IFS='|' read -r _ url _
        printf '%s' "$url"
    }
}

cmd_update() {
    ensure_dirs
    n=0

    tmpdir="/tmp/apt-update-$$"
    mkdir -p "$tmpdir"

    parse_sources < "$SOURCES_LIST" > "$tmpdir/sources"
    [ -d "/etc/apt/sources.list.d" ] && for sf in /etc/apt/sources.list.d/*.list; do
        [ -f "$sf" ] && parse_sources < "$sf" >> "$tmpdir/sources" 2>/dev/null
    done

    while IFS='|' read -r type url dist components; do
        n=$((n + 1))
        info "Get:$n $dist $components"

        safe="$(echo "$url" | $BBOX sed 's|https\?://||;s|/|_|g')"

        rel_url="$url/dists/$dist/Release"
        rel_file="$tmpdir/Release"
        if wget_download "$rel_url" "$rel_file"; then
            cp "$rel_file" "${APT_LISTS_DIR}/${safe}_${dist}_Release" 2>/dev/null
        else
            info "  Skipping $dist (could not fetch Release)"
            continue
        fi

        for comp in $components; do
            ok=0
            for arch in "amd64" "all"; do
                for ext in "xz" "gz"; do
                    pkg_url="$url/dists/$dist/$comp/binary-$arch/Packages.$ext"
                    pkg_file="$tmpdir/Packages_${comp}_${arch}.${ext}"
                    pkg_out="${APT_LISTS_DIR}/${safe}_${dist}_${comp}_binary-${arch}_Packages"

                    if wget_download "$pkg_url" "$pkg_file"; then
                        case "$ext" in
                            gz) busybox gunzip -c "$pkg_file" > "$pkg_out" 2>/dev/null ;;
                            xz) busybox xz -dc "$pkg_file" > "$pkg_out" 2>/dev/null ;;
                        esac
                        if [ -s "$pkg_out" ]; then
                            count=$(wc -l < "$pkg_out")
                            info "  OK $comp/$arch ($((count / 10)) packages)"
                            ok=1; break
                        fi
                    fi
                done
                [ "$ok" -eq 1 ] && break
            done
            [ "$ok" -eq 0 ] && info "  WARNING: $comp - no Packages file found"
        done
    done < "$tmpdir/sources"

    rm -rf "$tmpdir"
    info "Done updating package lists"
}

is_installed() {
    _pkg="$1"
    dpkg_ok=$(awk -v pkg="$_pkg" '/^Package: /{p=$2; s=""} p==pkg && /^Status: /{s=$0; exit} END{if(s && s ~ /install ok installed$/) print "yes"}' "$STATUS_DB" 2>/dev/null)
    if [ -n "$dpkg_ok" ]; then
        info "  [debug] is_installed($_pkg)=true (dpkg status)"
        return 0
    fi
    if pkg_has_files "$_pkg"; then
        info "  [debug] is_installed($_pkg)=true (files exist on disk)"
        return 0
    fi
    info "  [debug] is_installed($_pkg)=false"
    return 1
}

extract_depends() {
    _pkg="$1"
    for _f in $(pkg_list_files); do
        _entry=$($BBOX sed -n "/^Package: $_pkg\$/,/^$/p" "$_f")
        _deps=$(printf '%s' "$_entry" | $BBOX sed -n 's/^Depends: //p')
        _predeps=$(printf '%s' "$_entry" | $BBOX sed -n 's/^Pre-Depends: //p')
        _combined=""
        [ -n "$_predeps" ] && _combined="${_combined}${_predeps}, "
        [ -n "$_deps" ] && _combined="${_combined}${_deps}"
        [ -n "$_combined" ] && { printf '%s' "$_combined"; return 0; }
    done
    return 1
}

pkg_has_files() {
    _pkg="$1"
    case "$_pkg" in
        libc6)     [ -f /usr/lib/libc.so.6 ] || [ -f /usr/lib/x86_64-linux-gnu/libc.so.6 ] ;;
        libyyjson0) [ -f /usr/lib/libyyjson.so.0 ] || [ -f /usr/lib/x86_64-linux-gnu/libyyjson.so.0 ] ;;
        gcc-14-base) [ -d /usr/share/doc/gcc-14-base ] ;;
        fastfetch) [ -f /usr/bin/fastfetch ] ;;
        *)         false ;;
    esac
}

install_pkg() {
    local pkg="$1"
    info "  [debug] install_pkg($pkg): enter"
    is_installed "$pkg" && { info "  [debug] install_pkg($pkg): already installed, skip"; return 0; }

    if pkg_has_files "$pkg"; then
        info "  [debug] install_pkg($pkg): files exist on disk, marking as installed"
        if ! grep -q "^Package: $pkg\$" "$STATUS_DB" 2>/dev/null; then
            {
                echo ""
                echo "Package: $pkg"
                echo "Status: install ok installed"
                echo "Priority: optional"
                echo "Section: misc"
                echo "Installed-Size: 1"
                echo "Architecture: amd64"
                echo "Version: 0.0-1"
                echo "Description: $pkg (locally present)"
            } >> "$STATUS_DB"
        fi
        return 0
    fi

    local found=0 pkg_filename="" pkg_version=""
    for f in $(pkg_list_files); do
        [ -f "$f" ] || continue
        info "  [debug] install_pkg($pkg): searching in $(basename $f)"
        local in_pkg=0
        while IFS= read -r line; do
            case "$line" in
                "Package: $pkg") in_pkg=1; pkg_version=""; pkg_filename=""; info "  [debug]   found entry for $pkg" ;;
                "Package: "*)
                    [ "$in_pkg" -eq 1 ] && [ -n "$pkg_filename" ] && { info "  [debug]   found Filename=$pkg_filename, break"; break; }
                    in_pkg=0
                    ;;
                "Version: "*)
                    [ "$in_pkg" -eq 1 ] && pkg_version="${line#Version: }"
                    ;;
                "Filename: "*)
                    [ "$in_pkg" -eq 1 ] && pkg_filename="${line#Filename: }"
                    ;;
                "")
                    [ "$in_pkg" -eq 1 ] && [ -n "$pkg_filename" ] && { info "  [debug]   found Filename=$pkg_filename at blank line, break"; break; }
                    in_pkg=0
                    ;;
            esac
        done < "$f"
        if [ "$in_pkg" -eq 1 ] && [ -n "$pkg_filename" ]; then
            found=1
            break
        fi
    done

    info "  [debug] install_pkg($pkg): found=$found, filename=$pkg_filename, version=$pkg_version"
    [ "$found" -eq 0 ] && { error "Package $pkg not found."; exit 1; }

    local full_url="${repo_url}/${pkg_filename}"
    local deb_name="${pkg_filename##*/}"
    local deb_file="/tmp/${deb_name}"

    if [ -f "$APT_ARCHIVE_DIR/${deb_name}" ]; then
        info "  [debug] install_pkg($pkg): using cached $deb_name"
        cp "$APT_ARCHIVE_DIR/${deb_name}" "$deb_file"
    else
        info "Downloading $pkg (${pkg_version:-unknown})..."
        if ! wget_download "$full_url" "$deb_file"; then
            error "Failed to download $pkg"
            rm -f "$deb_file"
            exit 1
        fi
        cp "$deb_file" "$APT_ARCHIVE_DIR/" 2>/dev/null
        info "  [debug] install_pkg($pkg): downloaded to $deb_file ($($BBOX wc -c < $deb_file) bytes)"
    fi
    info "Installing $pkg..."
    dpkg_out=$("$DPKG" -i "$deb_file" 2>&1)
    dpkg_rc=$?
    echo "$dpkg_out" | while IFS= read -r line; do info "  [dpkg] $line"; done
    if [ $dpkg_rc -ne 0 ]; then
        warn "dpkg failed for $pkg (exit $dpkg_rc)"
        if pkg_has_files "$pkg"; then
            warn "Files already present, marking as installed despite dpkg error"
            rm -f "$deb_file"
            return 0
        fi
        error "Failed to install $pkg (dpkg exit code $dpkg_rc)"
        rm -f "$deb_file"
        exit $dpkg_rc
    fi
    info "  [debug] install_pkg($pkg): dpkg returned 0"
    _configured=$(awk -v pkg="$pkg" '/^Package: /{p=$2} p==pkg && /^Status: /{if(/install ok installed$/) print 1}' "$STATUS_DB" 2>/dev/null)
    if [ "$_configured" != "1" ]; then
        warn "$pkg not fully configured after dpkg, running dpkg --configure..."
        "$DPKG" --configure "$pkg" 2>&1 | while IFS= read -r line; do info "  [dpkg] $line"; done
    fi
    rm -f "$deb_file"
}

resolve_deps() {
    local pkg="$1"
    info "  [debug] resolve_deps($pkg): enter"
    grep -qx "$pkg" "$MARKED_FILE" 2>/dev/null && { info "  [debug] resolve_deps($pkg): already in marked, skip"; return 0; }
    echo "$pkg" >> "$MARKED_FILE"

    local deps=$(extract_depends "$pkg")
    info "  [debug] resolve_deps($pkg): deps='$deps'"
    [ -z "$deps" ] && { info "  [debug] resolve_deps($pkg): no deps"; return 0; }

    local pkg_files=""
    for f in $(ls "$APT_LISTS_DIR"/*_Packages 2>/dev/null); do
        pkg_files="$pkg_files${pkg_files:+ }$f"
    done

    local dep_list=$(printf '%s\n' "$deps" | $BBOX sed 's/, */,/g' | $BBOX tr ',' '\n')

    local newline_only='
'
    local old_ifs="$IFS"; IFS="$newline_only"
    for dep_group in $dep_list; do
        IFS="$old_ifs"
        dep_group="$(printf '%s' "$dep_group" | $BBOX sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        [ -z "$dep_group" ] && continue

        local found=0
        local alt alt_name
        for alt in $(printf '%s' "$dep_group" | $BBOX tr '|' '\n'); do
            alt_name="$(printf '%s' "$alt" | $BBOX sed 's/:any$//; s/[[:space:]]*([^)]*)[[:space:]]*//g; s/^[[:space:]]*//;s/[[:space:]]*$//')"
            [ -z "$alt_name" ] && continue
            info "  [debug] resolve_deps($pkg): check dep '$alt_name'"
            is_installed "$alt_name" && { info "  [debug] resolve_deps($pkg): '$alt_name' is installed, skip"; found=1; break; }
            grep -qx "$alt_name" "$MARKED_FILE" 2>/dev/null && { info "  [debug] resolve_deps($pkg): '$alt_name' in marked, skip"; found=1; break; }
        done
        [ "$found" -eq 1 ] && continue

        info "  [debug] resolve_deps($pkg): need to install '$alt_name'"
        local _resolved _providing
        for alt in $(printf '%s' "$dep_group" | $BBOX tr '|' '\n'); do
            alt_name="$(printf '%s' "$alt" | $BBOX sed 's/:any$//; s/[[:space:]]*([^)]*)[[:space:]]*//g; s/^[[:space:]]*//;s/[[:space:]]*$//')"
            [ -z "$alt_name" ] && continue
            _resolved=""
            for pkg_f in $pkg_files; do
                if grep -q "^Package: $alt_name\$" "$pkg_f" 2>/dev/null; then
                    _resolved="$alt_name"; break
                fi
            done
            if [ -z "$_resolved" ]; then
                for pkg_f in $pkg_files; do
                    _providing=$($BBOX sed -n "/^Package: /{h};/^Provides: .*$alt_name\(,\| \|\$\)/{g;s/^Package: //p}" "$pkg_f" 2>/dev/null | head -1)
                    [ -n "$_providing" ] && { _resolved="$_providing"; break; }
                done
            fi
            if [ -n "$_resolved" ]; then
                info "  [debug] resolve_deps($pkg): resolving '$_resolved'..."
                resolve_deps "$_resolved"
                install_pkg "$_resolved"
                found=1; break
            fi
        done
        if [ "$found" -eq 0 ]; then
            warn "Unresolved dependency '$dep_group' for $pkg"
        fi
        IFS="$newline_only"
    done
    IFS="$old_ifs"
}

cmd_install() {
    [ $# -eq 0 ] && { error "No package name provided"; echo "Usage: apt install <package>..."; exit 1; }
    info "[debug] cmd_install: starting, packages: $*"
    ensure_dirs

    repo_url=$(get_repo_url)
    info "[debug] cmd_install: repo_url='$repo_url'"
    [ -z "$repo_url" ] && { error "No repository found in sources.list"; exit 1; }

    MARKED_FILE="/tmp/apt-marked-$$"
    > "$MARKED_FILE"
    info "[debug] cmd_install: MARKED_FILE=$MARKED_FILE"

    for pkg in "$@"; do
        info "[debug] cmd_install: processing pkg=$pkg"
        case "$pkg" in
            /*|./*|../*)
                if [ -f "$pkg" ]; then
                    info "Installing local package $pkg..."
                    cp "$pkg" "$APT_ARCHIVE_DIR/" 2>/dev/null
                    "$DPKG" -i "$pkg" 2>&1 || {
                        rc=$?
                        error "Failed to install $pkg (dpkg exit code $rc)"
                        exit $rc
                    }
                else
                    error "File $pkg not found"
                    exit 1
                fi
                continue
                ;;
        esac
        if is_installed "$pkg"; then
            info "$pkg is already installed"
            continue
        fi
        resolve_deps "$pkg"
        install_pkg "$pkg"
    done
    rm -f "$MARKED_FILE"
    info "Done installing packages"
}

cmd_remove() {
    [ $# -eq 0 ] && { error "No package name provided"; echo "Usage: apt remove <package>..."; exit 1; }
    for pkg in "$@"; do
        info "Removing $pkg..."
        "$DPKG" -r "$pkg" 2>&1 || error "Failed to remove $pkg"
    done
    info "Done removing packages"
}

cmd_purge() {
    [ $# -eq 0 ] && { error "No package name provided"; echo "Usage: apt purge <package>..."; exit 1; }
    for pkg in "$@"; do
        info "Purging $pkg..."
        "$DPKG" -P "$pkg" 2>&1 || error "Failed to purge $pkg"
    done
    info "Done purging packages"
}

cmd_upgrade() {
    ensure_dirs
    [ -f "$STATUS_DB" ] || { info "No packages installed"; return; }

    upgradable=""
    inst_pkgs=$(awk 'BEGIN{p=""} /^Package: /{p=$2} p && /^Status: / && $0 ~ /install ok installed$/{print p; p=""}' "$STATUS_DB")

    for inst_pkg in $inst_pkgs; do
        [ -z "$inst_pkg" ] && continue
        inst_ver=$($BBOX sed -n "/^Package: $inst_pkg\$/,/^$/p" "$STATUS_DB" | $BBOX sed -n 's/^Version: //p')
        cand_ver=""
        for f in $(pkg_list_files); do
            [ -f "$f" ] || continue
            cand_ver=$($BBOX sed -n "/^Package: $inst_pkg\$/,/^$/p" "$f" | $BBOX sed -n 's/^Version: //p')
            [ -n "$cand_ver" ] && break
        done
        [ -n "$cand_ver" ] && [ "$cand_ver" != "$inst_ver" ] && {
            info "  $inst_pkg: $inst_ver -> $cand_ver"
            upgradable="$upgradable $inst_pkg"
        }
    done

    [ -z "$upgradable" ] && { info "All packages are up to date"; return; }
    info "The following packages will be upgraded:${upgradable}"
    cmd_install $upgradable
}

cmd_list() {
    show_installed=0
    for arg in "$@"; do [ "$arg" = "--installed" ] && show_installed=1; done

    if [ "$show_installed" -eq 1 ]; then
        [ -f "$STATUS_DB" ] || return
        printf "%-30s %-20s %s\n" "Package" "Version" "Description"
        echo "----------------------------------------------------------------"
        $BBOX sed -n '/^Package: /{N;N;/Status: install ok installed/{s/^Package: //;s/\nVersion: /|/;s/\n.*Description: /|/;p}}' "$STATUS_DB" | \
        while IFS='|' read -r name ver desc; do
            printf "%-30s %-20s %s\n" "$name" "$ver" "$desc"
        done
    else
        printf "%-30s %-20s %-10s %s\n" "Package" "Version" "Status" "Description"
        echo "----------------------------------------------------------------------"
        for f in $(pkg_list_files); do
            [ -f "$f" ] || continue
            pkg_name=""; pkg_version=""; pkg_desc=""
            while IFS= read -r line; do
                case "$line" in
                    "Package: "*) pkg_name="${line#Package: }" ;;
                    "Version: "*) pkg_version="${line#Version: }" ;;
                    "Description: "*) pkg_desc="${line#Description: }" ;;
                    "")
                        if [ -n "$pkg_name" ]; then
                            awk -v pkg="$pkg_name" '/^Package: /{p=$2; s=""} p==pkg && /^Status: /{s=$0; exit} END{if(s && s ~ /install ok installed$/) print "yes"}' "$STATUS_DB" 2>/dev/null | grep -q "yes" && \
                            status="installed" || status="available"
                            printf "%-30s %-20s %-10s %s\n" "$pkg_name" "$pkg_version" "$status" "${pkg_desc:-}"
                        fi
                        pkg_name=""; pkg_version=""; pkg_desc=""
                        ;;
                esac
            done < "$f"
        done
    fi
}

cmd_search() {
    [ $# -eq 0 ] && { error "Search pattern required"; echo "Usage: apt search <pattern>"; exit 1; }
    pattern="$1"; found=0
    for f in $(pkg_list_files); do
        [ -f "$f" ] || continue
        pkg=""; desc=""
        while IFS= read -r line; do
            case "$line" in
                "Package: "*) pkg="${line#Package: }" ;;
                "Description: "*) desc="${line#Description: }" ;;
                "")
                    [ -n "$pkg" ] && case "$pkg" in *"$pattern"*)
                        echo "$pkg - $desc"
                        found=$((found + 1))
                    esac
                    pkg=""; desc=""
                    ;;
            esac
        done < "$f"
    done
    [ "$found" -eq 0 ] && warn "No packages found matching '$pattern'" || info "Found $found packages"
}

cmd_show() {
    [ $# -eq 0 ] && { error "No package name provided"; echo "Usage: apt show <package>"; exit 1; }
    found=0
    for db in "$STATUS_DB" $(pkg_list_files); do
        [ -f "$db" ] || continue
        in_target=0
        while IFS= read -r line; do
            case "$line" in
                "Package: $1") in_target=1; found=1; echo "$line" ;;
                "Package: "*)
                    [ "$in_target" -eq 1 ] && echo ""
                    in_target=0
                    ;;
                "")
                    [ "$in_target" -eq 1 ] && echo ""
                    [ "$in_target" -eq 1 ] && [ "$db" = "$STATUS_DB" ] && break
                    in_target=0
                    ;;
                *) [ "$in_target" -eq 1 ] && echo "$line" ;;
            esac
        done < "$db"
        [ "$found" -eq 1 ] && break
    done
    [ "$found" -eq 0 ] && error "Package $1 not found"
}

cmd_autoremove() {
    info "Checking for auto-removable packages..."
    auto_pkgs=$($BBOX sed -n '/^Package: /{s/^Package: //;h};/^Auto-Installed: yes/{g;p}' "$STATUS_DB" 2>/dev/null)
    [ -z "$auto_pkgs" ] && { info "No packages to remove"; return; }
    info "Packages to remove: $auto_pkgs"
    for pkg in $auto_pkgs; do
        "$DPKG" -r "$pkg" 2>&1 || warn "Failed to remove $pkg"
    done
    info "Done"
}

cmd_clean() {
    info "Cleaning package cache..."
    rm -f "$APT_ARCHIVE_DIR"/*.deb 2>/dev/null
    info "Done"
}

cmd_autoclean() {
    info "Removing obsolete package files..."
    for f in "$APT_ARCHIVE_DIR"/*.deb; do
        [ -f "$f" ] || continue
        pkg="${f##*/}"; pkg="${pkg%%_*}"
        grep -q "^Package: $pkg\$" "$STATUS_DB" 2>/dev/null || {
            rm -f "$f"
            info "  Removed $pkg"
        }
    done
    info "Done"
}

cmd_help() {
    cat << 'HELP'
Usage: apt [options] <command> [arguments]

Commands:
  update            - Update package lists from repositories
  install <pkg>...  - Install package(s)
  remove <pkg>...   - Remove package(s)
  purge <pkg>...    - Remove package(s) and config files
  upgrade           - Upgrade all installed packages
  list              - List available packages
  list --installed  - List installed packages
  search <pattern>  - Search for packages
  show <pkg>        - Show package details
  autoremove        - Remove auto-installed unused packages
  clean             - Clear downloaded package cache
  autoclean         - Remove obsolete package files
  help              - Show this help message
HELP
}

main() {
    [ $# -eq 0 ] && { cmd_help; exit 0; }
    case "$1" in
        update) cmd_update ;;
        install) shift; cmd_install "$@" ;;
        remove) shift; cmd_remove "$@" ;;
        purge) shift; cmd_purge "$@" ;;
        upgrade) cmd_upgrade ;;
        list) shift; cmd_list "$@" ;;
        search) shift; cmd_search "$@" ;;
        show) shift; cmd_show "$@" ;;
        autoremove) cmd_autoremove ;;
        clean) cmd_clean ;;
        autoclean) cmd_autoclean ;;
        help|--help|-h) cmd_help ;;
        *) error "Unknown command: $1"; cmd_help; exit 1 ;;
    esac
}

main "$@"
